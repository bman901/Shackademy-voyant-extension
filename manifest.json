{
  "manifest_version": 3,
  "name": "Shackademy — Voyant Help",
  "version": "1.0.0",
  "description": "Adds field-level guidance and Shackademy lesson links to Voyant financial planning software. For Shackademy members only.",
  "homepage_url": "https://shackademy.com/privacy",
  "permissions": ["activeTab", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Toggle Shackademy help",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.planwithvoyant.co.uk/*"],
      "js": ["fields.js", "lessons.js", "sections.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["fields.js", "lessons.js", "sections.js"],
      "matches": ["https://www.planwithvoyant.co.uk/*"]
    }
  ]
}