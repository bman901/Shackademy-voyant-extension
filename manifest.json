{
  "manifest_version": 3,
  "name": "Shackademy - Voyant Help",
  "version": "0.4.0",
  "description": "Adds Shackademy guidance to Voyant fields. Fully self-contained - no data leaves your browser.",
  "permissions": ["activeTab", "scripting", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Toggle Shackademy help",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["fields.js", "lessons.js", "sections.js"],
      "matches": ["<all_urls>"]
    }
  ]
}